# Copiar a .env en el servidor y completar con valores reales.
# NO commitear el archivo .env real.

# Dominio que apunta (registro A) al IP del VPS de DonWeb.
DOMAIN=admin.tu-dominio.com

# URL de la API. NEXT_PUBLIC_* se incrusta en el build del cliente.
NEXT_PUBLIC_API=https://api.tu-dominio.com

# URL del socket (puede ser la misma que la API).
NEXT_PUBLIC_SOCKET_URL=https://api.tu-dominio.com

# API usada en el servidor (SSR). Normalmente igual a NEXT_PUBLIC_API.
API=https://api.tu-dominio.com
